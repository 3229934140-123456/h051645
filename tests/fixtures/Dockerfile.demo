FROM scratch AS base
LABEL maintainer="test@example.com"
ARG VERSION=1.0.0
ENV APP_VERSION=${VERSION}
ENV NODE_ENV=production
WORKDIR /app

COPY requirements.txt /app/
COPY src/ /app/src/

RUN mkdir -p /app/data && \
    echo "hello world" > /app/data/hello.txt && \
    echo "version is ${APP_VERSION}" > /app/data/version.txt

RUN rm /app/data/hello.txt

RUN echo "new file" > /app/added.txt

LABEL org.example.app="mini-builder-demo"
EXPOSE 8080 9090
VOLUME /app/data
USER nobody
CMD ["python", "-m", "http.server", "8080"]
ENTRYPOINT ["/bin/sh", "-c"]
